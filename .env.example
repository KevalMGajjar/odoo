# Copy to .env and fill in real values.

# Postgres connection string.
#  - Local:  postgresql://postgres:PASSWORD@localhost:5432/transitops?schema=public
#  - Neon:   postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/transitops?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/transitops?schema=public"

# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Gmail SMTP for password-reset emails (optional — without it, reset links are logged, not sent).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-16-char-gmail-app-password"
